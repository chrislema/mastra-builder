{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "implementation-note.schema.json",
  "title": "Implementation Note",
  "type": "object",
  "required": ["artifact_type", "task", "changes", "files_touched", "assumptions", "verification", "risks"],
  "properties": {
    "artifact_type": { "const": "implementation-note" },
    "task": { "type": "string", "minLength": 1 },
    "changes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "files_touched": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "assumptions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "verification": {
      "type": "object",
      "required": ["performed", "missing"],
      "properties": {
        "performed": {
          "description": "Each entry names the check and its evidence reference (run output, log, inspection).",
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "missing": {
          "description": "Verification that has NOT happened. Visible gaps score higher than hidden ones — never leave this implicit.",
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "risks": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
