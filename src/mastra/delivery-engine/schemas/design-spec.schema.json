{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "design-spec.schema.json",
  "title": "Design Spec",
  "type": "object",
  "required": ["artifact_type", "intent", "visual_direction", "key_surfaces", "interaction_notes", "implementation_notes"],
  "properties": {
    "artifact_type": { "const": "design-spec" },
    "intent": { "type": "string", "minLength": 1 },
    "visual_direction": {
      "type": "object",
      "required": ["typography", "color", "layout"],
      "properties": {
        "typography": {
          "description": "Exactly one approved Google Font with weight usage (700/800 headings, 400 body).",
          "type": "string",
          "minLength": 1
        },
        "color": {
          "description": "Brand color plus the tinted-neutral palette derivations with lightness targets and a usage mapping.",
          "type": "string",
          "minLength": 1
        },
        "layout": { "type": "string", "minLength": 1 },
        "motion": { "type": "string" }
      }
    },
    "key_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "hierarchy"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "hierarchy": {
            "description": "Primary content, secondary content, and navigation for this surface.",
            "type": "string",
            "minLength": 1
          },
          "states": {
            "description": "Loading, empty, and edge states designed for this surface.",
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "interaction_notes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "implementation_notes": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
