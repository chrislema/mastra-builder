{
  "$comment": "Single source of truth for role file boundaries and turn budgets. Consumed by the Mastra workspace beforeToolCall hook, deterministic file_ownership / write_paths_in_boundary checks, and delivery workflow stages. Globs are relative to the target repo root.",
  "planner": {
    "max_turns": 30,
    "owned": [],
    "forbidden": ["**"]
  },
  "architect": {
    "max_turns": 30,
    "owned": [],
    "forbidden": ["**"]
  },
  "engineer": {
    "max_turns": 40,
    "owned": [
      "package.json",
      "package-lock.json",
      "pnpm-lock.yaml",
      "yarn.lock",
      "bun.lockb",
      "tsconfig*.json",
      "*.config.*",
      "functions/_middleware.js",
      "functions/api/_middleware.js",
      "functions/**",
      "workers/**",
      "src/**",
      "lib/**",
      "scripts/**",
      "db/**",
      "migrations/**",
      "wrangler.jsonc",
      "wrangler.toml",
      "**/*.sql"
    ],
    "forbidden": ["public/**", "tests/**", "server/**", "api/**", "app/**", "prisma/**", "**/*.jsx", "**/*.tsx", "next.config.*"]
  },
  "designer": {
    "max_turns": 40,
    "owned": [
      "public/**",
      "assets/**",
      "styles/**",
      "src/**/*.html",
      "src/**/*.css",
      "src/**/*.js",
      "src/**/*.mjs",
      "src/assets/**"
    ],
    "forbidden": [
      "functions/**",
      "workers/**",
      "server/**",
      "api/**",
      "src/api/**",
      "src/server/**",
      "src/lib/server/**",
      "db/**",
      "prisma/**",
      "tests/**",
      "wrangler.jsonc",
      "wrangler.toml",
      "**/*.sql",
      "**/*.jsx",
      "**/*.tsx",
      "next.config.*"
    ]
  },
  "tester": {
    "max_turns": 40,
    "owned": ["tests/**", "test/**", "e2e/**", "playwright.config.*", "vitest.config.*"],
    "forbidden": ["functions/**", "workers/**", "public/**", "src/**", "app/**", "server/**", "api/**"]
  },
  "deployer": {
    "max_turns": 20,
    "owned": [],
    "forbidden": ["**"]
  }
}
